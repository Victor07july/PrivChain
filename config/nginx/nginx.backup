# Configuração principal do nginx para ambiente containerizado
user nginx;
worker_processes auto;
error_log /var/log/nginx/error.log notice;
pid /var/run/nginx.pid;

# Configurações de eventos
events {
    worker_connections 4096;  # Aumentado para suportar mais conexões simultâneas
    use epoll;
    multi_accept on;
}

# Configurações HTTP
http {
    # Configurações básicas
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    # Configurações de performance para alta carga
    client_body_timeout 60s;
    client_header_timeout 60s;
    send_timeout 60s;
    reset_timedout_connection on;

    # Formato de log
    log_format main '$remote_addr - $remote_user [$time_local] "$request" '
                    '$status $body_bytes_sent "$http_referer" '
                    '"$http_user_agent" "$http_x_forwarded_for"';

    access_log /var/log/nginx/access.log main;

    # Configurações de performance
    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout 65;
    types_hash_max_size 2048;
    client_max_body_size 16M;

    # Configurações de compressão
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types
        text/plain
        text/css
        text/xml
        text/javascript
        application/json
        application/javascript
        application/xml+rss
        application/atom+xml
        image/svg+xml;

    # Configurações de upstream para os containers
    upstream auth_service {
        server auth-service:8000;
        # Configurações de saúde do upstream
        keepalive 128;
        keepalive_requests 1000;
    }

    upstream rpc_user_service {
        server rpcnode-user:8545;  # Corrigido para porta RPC HTTP correta
        # Configurações de saúde do upstream
        keepalive 256;  # Aumentado para suportar alta carga de workers
        keepalive_requests 10000;
        keepalive_timeout 300s;
    }

    upstream chain-explorer {
        server chain-explorer:25000;
        # Configurações de saúde do upstream
        keepalive 128;
        keepalive_requests 1000;
    }

    # Servidor HTTP - Redireciona para HTTPS
    server {
        listen 80;
        server_name localhost;

        # Redirecionar todo tráfego HTTP para HTTPS
        location / {
            return 301 https://$host$request_uri;
        }
    }

    # Servidor HTTPS principal
    server {
        listen 443 ssl "http2";
        server_name localhost;

        # Configuração SSL
        ssl_certificate /etc/nginx/ssl/nginx-selfsigned.crt;
        ssl_certificate_key /etc/nginx/ssl/nginx-selfsigned.key;

        # Configurações SSL otimizadas
        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_prefer_server_ciphers off;
        ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
        ssl_session_timeout 1d;
        ssl_session_cache shared:SSL:50m;
        ssl_session_tickets off;

        # Headers de segurança
        add_header X-Frame-Options DENY always;
        add_header X-Content-Type-Options nosniff always;
        add_header X-XSS-Protection "1; mode=block" always;
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;

        # Configurações de proxy padrão
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;

        # Timeouts (aumentados para suportar alta carga)
        proxy_connect_timeout 60s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;

        # Buffer settings para melhor performance
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;

        # Roteamento para a API do auth-service
        location /api/ {
            proxy_pass http://auth_service/api/;

            # Headers específicos para o serviço de auth
            proxy_set_header X-Original-URI $request_uri;
            proxy_set_header X-Original-Method $request_method;
        }

        # Roteamento para o endpoint /admin
        location /admin {
            # Remove o prefixo /admin se necessário (descomente se quiser)
            # rewrite ^/admin/(.*) /$1 break;

            proxy_pass http://auth_service/;

            # Headers específicos para o serviço de auth
            proxy_set_header X-Original-URI $request_uri;
            proxy_set_header X-Original-Method $request_method;
        }

        # Roteamento para subpaths do /admin
        location /admin/ {
            proxy_pass http://auth_service/;

            # Headers específicos para o serviço de auth
            proxy_set_header X-Original-URI $request_uri;
            proxy_set_header X-Original-Method $request_method;
        }

        # Roteamento para o endpoint /user
        location /user {
            # Remove o prefixo /user se necessário (descomente se quiser)
            # rewrite ^/user/(.*) /$1 break;

            proxy_pass http://rpc_user_service/;

            # Headers específicos para o serviço RPC
            proxy_set_header X-Original-URI $request_uri;
            proxy_set_header X-Original-Method $request_method;

            # Configurações otimizadas para alta carga de workers
            proxy_http_version 1.1;
            proxy_set_header Connection "";

            # Timeouts específicos para RPC
            proxy_connect_timeout 60s;
            proxy_send_timeout 180s;
            proxy_read_timeout 180s;
        }

        # Roteamento para subpaths do /user
        location /user/ {
            proxy_pass http://rpc_user_service/;

            # Headers específicos para o serviço RPC
            proxy_set_header X-Original-URI $request_uri;
            proxy_set_header X-Original-Method $request_method;

            # Configurações otimizadas para alta carga de workers
            proxy_http_version 1.1;
            proxy_set_header Connection "";

            # Timeouts específicos para RPC (podem demorar mais)
            proxy_connect_timeout 60s;
            proxy_send_timeout 180s;
            proxy_read_timeout 180s;

            # Limite de taxa (opcional - descomente se quiser limitar)
            # limit_req zone=rpc_limit burst=100 nodelay;
        }

        # Roteamento para subpaths do /explorer
        location / {
            proxy_pass http://chain-explorer/;

            # Headers específicos para o serviço Explorer
            proxy_set_header X-Original-URI $request_uri;
            proxy_set_header X-Original-Method $request_method;
        }

        # Health check endpoint
        location /health {
            access_log off;
            return 200 "healthy\n";
            add_header Content-Type text/plain;
        }

        # Página de erro customizada para 404
        # location / {
        #     return 404 '{"error": "Endpoint not found", "message": "Available endpoints: /admin, /user"}';
        #     add_header Content-Type application/json;
        # }

        # Configuração de erro
        error_page 500 502 503 504 /50x.html;
        location = /50x.html {
            root /usr/share/nginx/html;
        }
    }
}